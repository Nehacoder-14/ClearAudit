# ============================================================
# ClearAudit - Environment Variables
# ============================================================
# Copy this file to .env and fill in the values.
# Required variables are marked with [REQUIRED].
# Optional variables have sensible defaults or graceful fallbacks.

# ============================================================
# App
# ============================================================
NODE_ENV=development                              # development | production | test
NEXT_PUBLIC_APP_URL=http://localhost:3000         # [REQUIRED] Public URL used for CORS, email links, redirects

# ============================================================
# Auth - NextAuth v5
# ============================================================
# Generate a secret: openssl rand -base64 32
AUTH_SECRET=                                      # [REQUIRED] NextAuth v5 secret (also accepted as NEXTAUTH_SECRET)
AUTH_URL=http://localhost:3000                     # NextAuth v5 base URL (alias: NEXTAUTH_URL)
NEXTAUTH_SECRET=                                  # Alias kept for backward compatibility
NEXTAUTH_URL=http://localhost:3000                 # Alias kept for backward compatibility

# ============================================================
# Auth - Google OAuth (optional)
# ============================================================
# Create credentials at https://console.cloud.google.com/apis/credentials
AUTH_GOOGLE_ID=                                   # Google OAuth Client ID (alias: GOOGLE_CLIENT_ID)
AUTH_GOOGLE_SECRET=                               # Google OAuth Client Secret (alias: GOOGLE_CLIENT_SECRET)
GOOGLE_CLIENT_ID=                                 # Alias kept for backward compatibility
GOOGLE_CLIENT_SECRET=                             # Alias kept for backward compatibility

# ============================================================
# Database - PostgreSQL 15+ with pgvector
# ============================================================
DATABASE_URL=postgresql://postgres:password@localhost:5432/clearaudit
DIRECT_URL=postgresql://postgres:password@localhost:5432/clearaudit
# Tip: Use docker-compose.yml to spin up a local PostgreSQL + Redis stack.
# If DATABASE_URL is not set, the app falls back to a local JSON file (clearaudit-db.json).

# ============================================================
# AI - Anthropic Claude (optional but recommended)
# ============================================================
# Get a key at https://console.anthropic.com/
# Without a key, the app uses a built-in rule-based fallback parser.
ANTHROPIC_API_KEY=

# ============================================================
# AI - OpenAI (optional, for embeddings)
# ============================================================
# Not currently used in the default pipeline. Reserved for future use.
OPENAI_API_KEY=

# ============================================================
# Redis (optional - enables BullMQ job queue)
# ============================================================
# Set USE_REDIS=true and provide connection details for production-grade
# background job processing. Without Redis, jobs run in-process.
USE_REDIS=false
REDIS_URL=redis://127.0.0.1:6379
UPSTASH_REDIS_REST_URL=                           # For Upstash Redis (serverless)
UPSTASH_REDIS_REST_TOKEN=

# ============================================================
# Stripe - Billing (test mode)
# ============================================================
# Get test keys at https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_...                      # Stripe secret key
STRIPE_WEBHOOK_SECRET=whsec_...                   # Stripe webhook signing secret
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...    # Stripe publishable key (exposed to client)
STRIPE_PRO_PRICE_ID=price_...                     # Stripe Price ID for the Pro tier

# ============================================================
# Email - SMTP (optional)
# ============================================================
# Without SMTP credentials, emails are logged to console in development.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=ClearAudit <noreply@clearaudit.app>

# ============================================================
# Security
# ============================================================
JWT_SECRET=                                       # Secret for JWT signing (used by auth layer)
ENCRYPTION_KEY=32-char-encryption-key-here!!      # 32-character AES encryption key for data at rest

# ============================================================
# Monitoring (optional)
# ============================================================
SENTRY_DSN=                                       # Sentry DSN for error tracking

# ============================================================
# Demo Mode
# ============================================================
# When true, allows /api/seed to run without authentication in development.
ALLOW_DEMO_SEED=true
